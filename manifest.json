{
  "manifest_version": 3,
  "name": "页面切换 Demo",
  "version": "1.0.0",
  "description": "使用共享上下文解决模块引用问题",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["pages/*.html", "pages/*.js", "libs/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}