{
  "manifest_version": 3,
  "name": "页面切换 Demo",
  "version": "1.0.0",
  "description": "使用状态管理实现页面切换的Chrome扩展",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pages/*.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}