{
  "manifest_version": 3,
  "name": "Testing Tools",
  "version": "1.0",
  "description": "测试工具",
  "permissions": [
    "storage",
    "clipboardWrite",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "favicon.ico",
    "48": "favicon.ico",
    "128": "favicon.ico"
  },
  "action": {
    "default_popup": "index.html"
  },
  "options_ui": {
    "page": "index.html",
    "open_in_tab": true
  }
}  