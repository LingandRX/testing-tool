{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "node"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true
  },
  "include": [
    "components/**/*.test.tsx",
    "components/**/*.tsx",
    "components/**/*.ts",
    "utils/**/*.ts",
    "utils/**/*.tsx",
    "vitest.setup.ts"
  ]
}
